{
  "name": "@simplesmoothsafe/dataverse-ops-mcp",
  "version": "0.3.0",
  "description": "Open-source MCP server for Microsoft Dataverse & Power Automate diagnostics: plugin traces, async jobs, flow runs, governance and documentation, over stdio.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sss-dclemente/dataverse-mcp-pro.git"
  },
  "homepage": "https://github.com/sss-dclemente/dataverse-mcp-pro#readme",
  "bugs": {
    "url": "https://github.com/sss-dclemente/dataverse-mcp-pro/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dataverse-ops-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx src/server.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dataverse",
    "dynamics-365",
    "power-platform",
    "plugin-trace",
    "diagnostics"
  ],
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
